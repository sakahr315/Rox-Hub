local RunService = game:GetService("RunService")

local Library = {}
Library.__index = Library

local _updateQueue = {}
local _updateConnection

local function StartUpdateLoop()
	if _updateConnection then return end
	task.spawn(function()
		while task.wait(0.1) do
			for label, value in pairs(_updateQueue) do
				pcall(function()
					label.Text = value
				end)
				_updateQueue[label] = nil
			end
		end
	end)
	_updateConnection = true
end

local function CreateScreenGui()
	if get_hidden_gui or gethui then
		local hui = (get_hidden_gui or gethui)()

		local Main = Instance.new("ScreenGui")
		Main.Name = "MRCScriptsUI"
		Main.ResetOnSpawn = false
		Main.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		Main.IgnoreGuiInset = true
		Main.Parent = hui

		return Main
	end

	if (not is_sirhurt_closure) and (syn and syn.protect_gui) then
		local cg
		local ok = pcall(function()
			cg = game:GetService("CoreGui")
		end)

		if ok and cg then
			local Main = Instance.new("ScreenGui")
			Main.Name = "MRCScriptsUI"
			Main.ResetOnSpawn = false
			Main.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
			Main.IgnoreGuiInset = true

			syn.protect_gui(Main)
			Main.Parent = cg

			return Main
		end
	end

	do
		local cg
		local ok = pcall(function()
			cg = game:GetService("CoreGui")
		end)

		if ok and cg then
			local rg = cg:FindFirstChild("RobloxGui")
			if rg then
				return rg
			end

			local Main = Instance.new("ScreenGui")
			Main.Name = "MRCScriptsUI"
			Main.ResetOnSpawn = false
			Main.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
			Main.IgnoreGuiInset = true
			Main.Parent = cg

			return Main
		end
	end

	local player = game:GetService("Players").LocalPlayer
	local playerGui = player and player:WaitForChild("PlayerGui", 5)

	local Main = Instance.new("ScreenGui")
	Main.Name = "MRCScriptsUI"
	Main.ResetOnSpawn = false
	Main.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	Main.IgnoreGuiInset = true
	Main.Parent = playerGui

	return Main
end

